# ── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:SENHA@localhost:5432/myapp_dev

# ── Sessão (iron-session) ────────────────────────────────────────────────────
# Mínimo 32 caracteres. Gere com: openssl rand -hex 32
SESSION_SECRET=troque-por-uma-string-aleatoria-de-32-chars-minimo

# ── Auth admin ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=troque-antes-de-usar

# ── Identidade da aplicação ──────────────────────────────────────────────────
# Injetadas pelo deploy (CI/CD) — defina localmente para dev
APP_NAME=minha-app
APP_VERSION=dev
GIT_COMMIT_SHORT=local

# ── Visível no browser (NEXT_PUBLIC_*) ───────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Minha Aplicação
