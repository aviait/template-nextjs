generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Exemplo de model — substitua pelo schema da aplicação
model Example {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @db.Timestamptz
  name      String

  @@map("examples")
}
